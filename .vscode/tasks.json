{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build/Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Flash and Run",
            "type": "shell",
            "command": "/Applications/STMicroelectronics/STM32Cube/STM32CubeProgrammer/STM32CubeProgrammer.app/Contents/MacOs/bin/STM32_Programmer_CLI",
            "args": [
                "-c",
                "port=SWD",
                "-w",
                "${workspaceFolder}/build/Debug/st.elf",
                "-v",
                "-rst"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build, Flash and Run",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Debug",
                "Flash and Run"
            ],
            "problemMatcher": []
        }
    ]
}
